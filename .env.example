# ── 数据库 ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://qq_user:qq_password@192.168.1.42:5432/qq_bot_v2

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── NapCat（QQ 协议端）────────────────────────────────────────────────────────
NAPCAT_WS_URL=ws://localhost:3001
NAPCAT_ACCESS_TOKEN=your_token_here

# ── Bot 基础配置 ───────────────────────────────────────────────────────────────
GROUP_IDS=955646333,672312932,253631878
SELF_NUMBER=3999414673

# ── 运行环境 ───────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── 媒体描述 ───────────────────────────────────────────────────────────────────
# 回复时等待媒体描述生成的最近 N 条消息数量（默认 5）
REPLY_MEDIA_WAIT_N=5
# 等待超时（毫秒），超时后降级为 [图片] 占位符（默认 5000）
REPLY_MEDIA_TIMEOUT_MS=5000

# ── LLM（OpenAI-compatible）───────────────────────────────────────────────────
# 所有场景的默认配置
OPENAI_BASE_URL=http://127.0.0.1:8317/v1
OPENAI_API_KEY=sk-local
OPENAI_MODEL=gpt-5.1

# ── 按场景覆盖 model / baseURL / apiKey（可选）───────────────────────────────
# 不填则继承默认值；baseURL 和 apiKey 通常只在接入不同服务商时才需要填
#
# LLM_DESCRIBE_IMAGE_MODEL=gpt-5.4-mini
# LLM_DESCRIBE_IMAGE_STREAM_MODE=fallback
# LLM_DESCRIBE_IMAGE_BASE_URL=
# LLM_DESCRIBE_IMAGE_API_KEY=
#
# LLM_DESCRIBE_VIDEO_MODEL=
# LLM_DESCRIBE_VIDEO_BASE_URL=
# LLM_DESCRIBE_VIDEO_API_KEY=
#
# LLM_DESCRIBE_PDF_MODEL=
# LLM_DESCRIBE_PDF_BASE_URL=
# LLM_DESCRIBE_PDF_API_KEY=
#
# LLM_SUMMARIZE_TEXT_MODEL=gpt-5.1
# LLM_GENERATE_TEXT_MODEL=gpt-5.1
# LLM_GENERATE_REPLY_MODEL=gpt-5.1
# LLM_TRANSCRIBE_AUDIO_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_TRANSCRIBE_AUDIO_API_KEY=
# LLM_TRANSCRIBE_AUDIO_MODEL=gemini-2.0-flash

# ── Agent（可选，不填则继承 OPENAI_* 默认值）─────────────────────────────────
# LLM_AGENT_BASE_URL=
# LLM_AGENT_API_KEY=
# LLM_AGENT_MODEL=gpt-5.1

# ── Tavily 网络搜索（可选）────────────────────────────────────────────────────
# TAVILY_API_KEY=tvly-xxxxx

# ── 日志文件（可选）───────────────────────────────────────────────────────────
# LOG_FILE_ENABLED=true
# LOG_FILE_PATH=/absolute/path/to/app.log

# ── 定时任务 ───────────────────────────────────────────────────────────────────
MEMORY_JOB_INTERVAL_HOURS=4
MEMORY_JOB_SKIP_THRESHOLD=20
JOB_INTER_DELAY_MS=200
