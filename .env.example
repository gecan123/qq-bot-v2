# ── 数据库 ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://qq_user:qq_password@192.168.1.42:5432/qq_bot_v2

# ── NapCat (QQ 协议端) ────────────────────────────────────────────────────────
NAPCAT_WS_URL=ws://localhost:3001
NAPCAT_ACCESS_TOKEN=your_token_here

# ── Bot 基础配置 ───────────────────────────────────────────────────────────────
# 多群白名单 (逗号分隔, 例: 111111,222222)。bot 只听 + 回复白名单内的群。
# 私聊不走白名单, 任意 QQ 好友都可以直接 DM bot (陌生 DM 在 ingress 层按 sub_type=friend 过滤)。
BOT_TARGET_GROUP_IDS=
# Bot 自身 QQ 号(过滤自身回灌)
SELF_NUMBER=

# Owner (创造者) — 可选. 同时给两个才生效, 单给一个会启动期 throw, 都不给则
# system prompt 不渲染 [关系基线] 段, Luna 把你当普通好友. 给了之后 Luna 知道
# QQ:xxx 这个号是 yyy 把她做出来的人, 跟你说话会更随意一点.
# BOT_OWNER_QQ=
# BOT_OWNER_NAME=

# ── 运行环境 ───────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── 媒体描述 ───────────────────────────────────────────────────────────────────
# 单条消息入站时等待媒体描述完成的预算(ms)
REPLY_MEDIA_TIMEOUT_MS=15000

# ── 队列 ───────────────────────────────────────────────────────────────────────
JOB_INTER_DELAY_MS=200

# ── Compaction 阈值 (可选) ────────────────────────────────────────────────────
# 估算 token 总数超过此值时触发 compaction. 默认 16000. 多源场景默认值 = 1× 单群预算 + 余量.
# COMPACTION_TRIGGER_TOKENS=16000

# ── Idle / Fetch (可选) ────────────────────────────────────────────────────────
# wait 工具长时间没事件时返回 [空闲提示] 的阈值. 默认 1800000 (30min).
# BOT_IDLE_HINT_MS=1800000
# list_reddit / get_reddit_post 单次 HTTP 超时 (AbortController). 默认 8000.
# BOT_REDDIT_TIMEOUT_MS=8000
# fetch_url 单次 HTTP 超时. 默认 12000.
# BOT_FETCH_URL_TIMEOUT_MS=12000
# NDJSON 旁路日志路径 (运维信息, 不进 Prisma). 默认 logs/fetch.ndjson.
# BOT_FETCH_LOG_PATH=logs/fetch.ndjson

# ── Per-group prompt customization (可选) ────────────────────────────────────
# 不同群配不同的 system prompt 段 (主题取向 + 节奏倾向). 改这个文件需要重启 bot
# (system prompt 字节变化, prompt cache 整段失效一次, 这是设计预期).
# 默认路径 ./prompts/groups.yaml; 文件必须存在 (loader fail-fast).
# yaml 内容可以是 `groups: []` 表示当前不做任何 per-group 定制 (跟无此特性等价).
# schema 详见文件内注释.
# BOT_GROUP_PROMPTS_PATH=./prompts/groups.yaml

# ── 主动发言白名单 (可选) ──────────────────────────────────────────────────────
# 逗号分隔的群 ID 列表. 只有在此列表内的群, send_message 的 group-ambient 分支
# (没有 replyToMessageId 的群发送) 才真发; 不在列表内的群走 dry-run (对 LLM 返回
# 假成功, 群友感知不到). reply / private 不受影响.
# 空 / 不配 = 全部 dry-run (安全默认值, 逐群开放).
# BOT_GROUP_AMBIENT_SEND_IDS=111,222

# ── LLM (provider 注册表 + 场景引用) ──────────────────────────────────────────
# agent chat 路径只支持 claude-code: bot 自己拼 3-block system (billing + agent + persona)
# + claude-cli UA + Anthropic-Beta 走 cliproxy → Anthropic. Anthropic 服务端按
# system.0.text 是否以 `x-anthropic-billing-header:` 开头判断 OAuth 信任; 没有这条
# fingerprint 就服务端注 ~2000 token Claude Code system prompt 覆盖你的人设。所以
# LLM_DEFAULT_PROVIDER 必须是 claude-code, 其它值启动期 throw。
# URL/API key 复用 LLM_PROVIDER_CLAUDE_* (不需要单独配 LLM_PROVIDER_CLAUDE_CODE_*).
# 启动期会发一条 persona-spoof 自检 (问"你是谁", 回答必须以"喵"开头), 失败 fail-fast。
LLM_DEFAULT_PROVIDER=claude-code
LLM_DEFAULT_MODEL=claude-opus-4-7

# 每个 provider 只定义一次 URL / API_KEY
# claude: agent 走 claude-code 时复用此 URL/key 指向 cliproxy (注意 LLM_DEFAULT_PROVIDER=claude-code,
#   provider 注册表里这条名字是 "claude")。
# openai / gemini: 仅供媒体路径 (describeImage / describeVideo / 等) 使用, 不影响 agent。
LLM_PROVIDER_CLAUDE_URL=http://127.0.0.1:8317/v1
LLM_PROVIDER_CLAUDE_API_KEY=sk-local
LLM_PROVIDER_OPENAI_URL=http://127.0.0.1:8317/v1
LLM_PROVIDER_OPENAI_API_KEY=sk-local
# LLM_PROVIDER_GEMINI_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_PROVIDER_GEMINI_API_KEY=

# 注意: 媒体路径若改用 Claude 系模型 (如 claude-haiku-*) 走 OpenAI SDK 经 cliproxy,
# Anthropic 服务端会按上述同样规则注入 CC system prompt 覆盖 describe-*.md 提示词,
# 导致结构化 JSON 输出降级为散文。要切之前先给 OpenAIProvider 加 3-block system
# 转换器 (content 字段送 array 形态), 否则 silent breakage。

# 场景路由(可选;不填则继承 default provider + default model)
# LLM_SCENARIO_DESCRIBE_IMAGE_PROVIDER=gemini
# LLM_SCENARIO_DESCRIBE_IMAGE_MODEL=gemini-3-flash-preview
#
# LLM_SCENARIO_DESCRIBE_VIDEO_PROVIDER=gemini
# LLM_SCENARIO_DESCRIBE_VIDEO_MODEL=gemini-3-flash-preview
#
# LLM_SCENARIO_DESCRIBE_PDF_PROVIDER=gemini
# LLM_SCENARIO_DESCRIBE_PDF_MODEL=gemini-3-flash-preview
#
# LLM_SCENARIO_TRANSCRIBE_AUDIO_PROVIDER=gemini
# LLM_SCENARIO_TRANSCRIBE_AUDIO_MODEL=gemini-3-flash-preview

# ── Tavily 网络搜索(可选)─────────────────────────────────────────────────────
# TAVILY_API_KEY=tvly-xxxxx

# ── 日志文件(可选)────────────────────────────────────────────────────────────
# LOG_FILE_ENABLED=true
# LOG_FILE_PATH=/absolute/path/to/app.log
