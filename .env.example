# ── 数据库 ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://qq_user:qq_password@192.168.1.42:5432/qq_bot_v2

# ── NapCat (QQ 协议端) ────────────────────────────────────────────────────────
NAPCAT_WS_URL=ws://localhost:3001
NAPCAT_ACCESS_TOKEN=your_token_here

# ── Bot 基础配置 ───────────────────────────────────────────────────────────────
# 多群白名单 (逗号分隔, 例: 111111,222222)。bot 只听 + 回复白名单内的群。
# 私聊不走白名单, 任意 QQ 好友都可以直接 DM bot (陌生 DM 在 ingress 层按 sub_type=friend 过滤)。
BOT_TARGET_GROUP_IDS=
# Bot 自身 QQ 号(过滤自身回灌)
SELF_NUMBER=

# Owner (创造者) — 可选. 同时给两个才生效, 单给一个会启动期 throw, 都不给则
# system prompt 不渲染 [关系基线] 段, Luna 把你当普通好友. 给了之后 Luna 知道
# QQ:xxx 这个号是 yyy 把她做出来的人, 跟你说话会更随意一点.
# BOT_OWNER_QQ=
# BOT_OWNER_NAME=

# ── 运行环境 ───────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── 媒体描述 ───────────────────────────────────────────────────────────────────
# 单条消息入站时等待媒体描述完成的预算(ms)
REPLY_MEDIA_TIMEOUT_MS=15000

# ── 队列 ───────────────────────────────────────────────────────────────────────
JOB_INTER_DELAY_MS=200
# mailbox drain 前等待同批消息聚合的时间(ms). 默认 3000.
# BOT_EVENT_DEBOUNCE_MS=3000

# ── Compaction 阈值 (可选) ────────────────────────────────────────────────────
# 估算 token 总数超过此值时触发 compaction. 默认 16000. 多源场景默认值 = 1× 单群预算 + 余量.
# COMPACTION_TRIGGER_TOKENS=16000

# ── Fetch (可选) ───────────────────────────────────────────────────────────────
# reddit action=list / action=get_post 单次 HTTP 超时 (AbortController). 默认 8000.
# BOT_REDDIT_TIMEOUT_MS=8000
# fetch_url 单次 HTTP 超时. 默认 12000.
# BOT_FETCH_URL_TIMEOUT_MS=12000
# NDJSON 旁路日志路径 (运维信息, 不进 Prisma). 默认 logs/fetch.ndjson.
# BOT_FETCH_LOG_PATH=logs/fetch.ndjson
# 统一 Tool Trace NDJSON 旁路日志路径 (运维信息, 不进 Prisma / AgentContext).
# 默认 logs/tool-calls.ndjson.
# BOT_TOOL_CALL_LOG_PATH=logs/tool-calls.ndjson
# Agent/compaction/Life Journal token usage NDJSON 路径. 默认 logs/token-usage.ndjson.
# BOT_TOKEN_USAGE_LOG_PATH=logs/token-usage.ndjson

# ── 真实浏览器能力 (可选) ─────────────────────────────────────────────────────
# 启用后注册单一 browser 工具. 需要另起 sidecar:
#   pnpm browser:controller
# 该 sidecar 会启动 headed CloakBrowser persistent profile.
# BOT_BROWSER_ENABLED=true
# BOT_BROWSER_CONTROLLER_URL=http://127.0.0.1:37921
# BOT_BROWSER_PROFILE_DIR=data/browser-profile/luna
# BOT_BROWSER_ARTIFACT_DIR=data/agent-workspace/browser
# BOT_BROWSER_ACTION_LOG_PATH=logs/browser-actions.ndjson
# BOT_BROWSER_ACTION_TIMEOUT_MS=15000
# BOT_BROWSER_ARTIFACT_MAX_FILES=50
# BOT_BROWSER_ARTIFACT_MAX_AGE_MS=1209600000  # 14d
# 默认 headed + persistent profile, 便于人工接管和保持登录态.
# BOT_BROWSER_HEADLESS=false
# BOT_BROWSER_HUMANIZE=true
# BOT_BROWSER_HUMAN_PRESET=default        # default | careful
# 需要代理/固定指纹时再打开; geoip 会用 mmdb-lib 按代理 IP 推断 timezone/locale.
# BOT_BROWSER_PROXY=http://user:pass@proxy.example:8080
# BOT_BROWSER_GEOIP=true
# BOT_BROWSER_TIMEZONE=Asia/Shanghai
# BOT_BROWSER_LOCALE=zh-CN
# BOT_BROWSER_ARGS=--fingerprint=12345
# BOT_BROWSER_EXTENSION_PATHS=/absolute/path/to/extension1,/absolute/path/to/extension2
# CloakBrowser 官方 env 仍由包本身读取:
# CLOAKBROWSER_CACHE_DIR=~/.cloakbrowser
# CLOAKBROWSER_BINARY_PATH=/absolute/path/to/Chromium
# CLOAKBROWSER_LICENSE_KEY=cb_xxxxxxxx

# ── Luna 个人网站维护 (可选) ─────────────────────────────────────────────────
# 启用后注册 deferred website capability. 仓库由 owner 首次创建并接入 Vercel;
# bot 只在受控路径内维护 Astro 内容, publish 会先检查再 commit/push.
# BOT_WEBSITE_ENABLED=true
# BOT_WEBSITE_REPO_DIR=/absolute/path/to/luna-site
# BOT_WEBSITE_PUBLIC_URL=https://luna.example.com
# BOT_WEBSITE_BRANCH=main
# BOT_WEBSITE_CHECK_COMMAND=pnpm build
# BOT_WEBSITE_COMMAND_TIMEOUT_MS=60000

# ── Per-group prompt customization (可选) ────────────────────────────────────
# 不同群配不同的 system prompt 段 (主题取向 + 节奏倾向). 改这个文件需要重启 bot
# (system prompt 字节变化, prompt cache 整段失效一次, 这是设计预期).
# 默认路径 ./prompts/groups.yaml; 文件不存在时回退为空配置, 不阻断启动.
# 需要定制时复制 prompts/groups.yaml.example 到 prompts/groups.yaml 再填写真实群号.
# BOT_GROUP_PROMPTS_PATH=./prompts/groups.yaml

# ── 主动发言白名单 (可选) ──────────────────────────────────────────────────────
# 逗号分隔的群 ID 列表. 只有在此列表内的群, send_message 的 group-ambient 分支
# 允许 ambient（不引用具体消息）发言的监听群。群 reply 只要求目标在监听群；私聊要求
# 目标是 NapCat 当前好友。不在列表内的群 ambient 会明确返回 rejected，不调用 NapCat。
# 空 / 不配 = 拒绝全部群 ambient（安全默认值，逐群开放）。
# BOT_GROUP_AMBIENT_SEND_IDS=111,222

# ── OutboundCache (出站图字节内存缓存) ────────────────────────────────────────
# 产字节工具 (generate_image / fetch_url image / screenshot) 写入, send_message 消费.
# 发送成功后 lazy persist 到 Media 表; 未发送的允许 TTL 过期自然淘汰.
# BOT_OUTBOUND_CACHE_MAX_ENTRIES=32
# BOT_OUTBOUND_CACHE_MAX_BYTES=104857600   # 100 MB
# BOT_OUTBOUND_CACHE_TTL_MS=3600000        # 1h

# ── LLM (provider 注册表 + 场景引用) ──────────────────────────────────────────
# agent chat 路径支持:
# - claude-code: bot 自己拼 3-block system (billing + agent + persona)
#   + claude-cli UA + Anthropic-Beta 走 cliproxy → Anthropic. Anthropic 服务端按
# system.0.text 是否以 `x-anthropic-billing-header:` 开头判断 OAuth 信任; 没有这条
# fingerprint 就服务端注 ~2000 token Claude Code system prompt 覆盖你的人设。所以
#   Claude 主路径必须用 claude-code identity。
# - openai-agent: 主 agent 走 OpenAI Chat Completions + 同一套工具 schema。
# LLM_DEFAULT_PROVIDER 必须是 claude-code 或 openai-agent, 其它值启动期 throw。
# URL/API key 复用 LLM_PROVIDER_CLAUDE_* (不需要单独配 LLM_PROVIDER_CLAUDE_CODE_*).
# claude-code 路径启动期会发 persona-spoof 自检 (问"你是谁", 回答必须以"喵"开头)。
# 调用失败/上游错误会短暂重试; 成功返回但不以"喵"开头才判定 cloak 异常并 fail-fast。
LLM_DEFAULT_PROVIDER=openai-agent
LLM_DEFAULT_MODEL=gpt-5.5

# 每个 provider 只定义一次 URL / API_KEY
# claude: agent 走 claude-code 时复用此 URL/key 指向 cliproxy。
# openai: agent 走 openai-agent 时复用此 URL/key；也供媒体路径使用。
# gemini: 仅供媒体路径 (describeImage / describeVideo / 等) 使用。
LLM_PROVIDER_CLAUDE_URL=http://127.0.0.1:8317/v1
LLM_PROVIDER_CLAUDE_API_KEY=sk-local
# 默认 any 强制每轮调用工具；Anthropic-compatible provider 不支持 any 时改为 auto。
LLM_PROVIDER_CLAUDE_TOOL_CHOICE=any
# Claude extended thinking: 默认关闭; prompt retention 默认仅保留当前 active tool cycle; 日志默认不落盘。
LLM_PROVIDER_CLAUDE_THINKING=disabled
LLM_PROVIDER_CLAUDE_THINKING_PROMPT_RETENTION=active-tool-cycle
LLM_PROVIDER_CLAUDE_THINKING_LOG=off
LLM_PROVIDER_OPENAI_URL=http://127.0.0.1:8317/v1
LLM_PROVIDER_OPENAI_API_KEY=sk-local
# LLM_PROVIDER_GEMINI_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_PROVIDER_GEMINI_API_KEY=

# 注意: 媒体路径若改用 Claude 系模型 (如 claude-haiku-*) 走 OpenAI SDK 经 cliproxy,
# Anthropic 服务端会按上述同样规则注入 CC system prompt 覆盖 describe-*.md 提示词,
# 导致结构化 JSON 输出降级为散文。要切之前先给 OpenAIProvider 加 3-block system
# 转换器 (content 字段送 array 形态), 否则 silent breakage。

# 场景路由(可选;不填则继承 default provider + default model)
# LLM_SCENARIO_DESCRIBE_IMAGE_PROVIDER=gemini
# LLM_SCENARIO_DESCRIBE_IMAGE_MODEL=gemini-3-flash-preview
# 可选: OpenAI-compatible reasoning effort (none/minimal/low/medium/high/xhigh/max).
# 只配置该字段也会创建场景路由；参数会严格发送，后端不支持时直接报错，不做 fallback 重试。
# LLM_SCENARIO_DESCRIBE_IMAGE_REASONING_EFFORT=low
#
# LLM_SCENARIO_DESCRIBE_VIDEO_PROVIDER=gemini
# LLM_SCENARIO_DESCRIBE_VIDEO_MODEL=gemini-3-flash-preview
#
# LLM_SCENARIO_DESCRIBE_PDF_PROVIDER=gemini
# LLM_SCENARIO_DESCRIBE_PDF_MODEL=gemini-3-flash-preview
#
# LLM_SCENARIO_TRANSCRIBE_AUDIO_PROVIDER=gemini
# LLM_SCENARIO_TRANSCRIBE_AUDIO_MODEL=gemini-3-flash-preview

# ── OpenBB CLI 查询 (可选) ──────────────────────────────────────────────────
# 启用后注册 openbb_cli 工具. 需要本机 PATH 里能运行 openbb CLI.
# 工具接收 OpenBB CLI 内部命令, 例如 /equity/price/historical --symbol AAPL --provider yfinance --export json.
# OPENBB_CLI_ENABLED=true
# OPENBB_CLI_BIN=openbb
# OPENBB_CLI_TIMEOUT_MS=15000

# ── Vibe-Trading 研究子 Agent (可选) ────────────────────────────────────────
# 启用后注册 deferred `trading_research` capability，内部工具是 trading_agent。
# 只允许 loopback HTTP；Vibe-Trading 服务端必须关闭 shell tools 和真实交易连接器。
# VIBE_TRADING_ENABLED=true
# VIBE_TRADING_BASE_URL=http://127.0.0.1:8899
# VIBE_TRADING_MODEL=gpt-5.5  # machine-local launcher reads this; qq-bot runtime does not send it
# VIBE_TRADING_REASONING_EFFORT=  # optional: low / medium / high / xhigh; only when the selected relay supports it
# VIBE_TRADING_API_KEY=replace-with-a-local-random-secret
# VIBE_TRADING_REQUEST_TIMEOUT_MS=15000
# VIBE_TRADING_TASK_TIMEOUT_MS=1800000
# VIBE_TRADING_POLL_INTERVAL_MS=2000
# VIBE_TRADING_RESULT_MAX_CHARS=12000

# ── Moomoo OpenD 官方 Skill (可选, 行情 + 证券模拟交易) ───────────────────
# 启用后 workspace_bash 支持受控 `moomoo <allowed command>` 子命令；交易写操作强制 SIMULATE.
# MOOMOO_SKILL_DIR 必须是官方包解压后的绝对 `skills/moomooapi` 目录.
# Python 建议使用单独 venv 的绝对解释器路径; OpenD 只连接本机 127.0.0.1.
# MOOMOO_SKILL_ENABLED=true
# MOOMOO_SKILL_DIR=/absolute/path/to/opend-skills/skills/moomooapi
# MOOMOO_PYTHON_BIN=/absolute/path/to/moomoo-venv/bin/python3
# MOOMOO_OPEND_PORT=11111
# MOOMOO_SKILL_TIMEOUT_MS=15000

# 本地 Crypto 模拟仓：只使用 Moomoo CC.*USD 行情，不调用 Crypto 实盘交易接口。
# CRYPTO_PAPER_ENABLED=false
# CRYPTO_PAPER_INITIAL_CASH=100000
# CRYPTO_PAPER_FEE_RATE_BPS=10

# ── Tavily 网络搜索(可选)─────────────────────────────────────────────────────
# TAVILY_API_KEY=tvly-xxxxx

# ── 日志文件(可选)────────────────────────────────────────────────────────────
# LOG_FILE_ENABLED=true
# LOG_FILE_PATH=/absolute/path/to/app.log
