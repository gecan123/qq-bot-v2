# ── 数据库 ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://qq_user:qq_password@192.168.1.42:5432/qq_bot_v2

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── NapCat（QQ 协议端）────────────────────────────────────────────────────────
NAPCAT_WS_URL=ws://localhost:3001
NAPCAT_ACCESS_TOKEN=your_token_here

# ── Bot 基础配置 ───────────────────────────────────────────────────────────────
GROUP_IDS=955646333,672312932,253631878
SELF_NUMBER=3999414673

# ── 运行环境 ───────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── 媒体描述 ───────────────────────────────────────────────────────────────────
# 回复时等待媒体描述生成的最近 N 条消息数量（默认 5）
REPLY_MEDIA_WAIT_N=5
# 等待超时（毫秒），超时后降级为 [图片] 占位符（默认 5000）
REPLY_MEDIA_TIMEOUT_MS=5000

# ── LLM（provider 注册表 + 场景引用）──────────────────────────────────────────
LLM_DEFAULT_PROVIDER=claude
LLM_DEFAULT_MODEL=gpt-5.1

# 每个 provider 只定义一次 URL / API_KEY
LLM_PROVIDER_CLAUDE_URL=http://127.0.0.1:8317/v1
LLM_PROVIDER_CLAUDE_API_KEY=sk-local
# LLM_PROVIDER_GEMINI_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_PROVIDER_GEMINI_API_KEY=
# LLM_PROVIDER_OPENAI_URL=https://api.openai.com/v1
# LLM_PROVIDER_OPENAI_API_KEY=

# 场景里只写“用哪个 provider / model”
# LLM_SCENARIO_DESCRIBE_IMAGE_PROVIDER=gemini
# LLM_SCENARIO_DESCRIBE_IMAGE_MODEL=gemini-3-flash-preview
# LLM_SCENARIO_DESCRIBE_IMAGE_FALLBACK_PROVIDER=claude
# LLM_SCENARIO_DESCRIBE_IMAGE_FALLBACK_MODEL=gpt-5.4
# LLM_SCENARIO_DESCRIBE_IMAGE_FALLBACK_GPT_STREAM_MODE=on
# LLM_SCENARIO_DESCRIBE_IMAGE_STREAM_MODE=fallback
#
# LLM_SCENARIO_DESCRIBE_VIDEO_PROVIDER=gemini
# LLM_SCENARIO_DESCRIBE_VIDEO_MODEL=gemini-3-flash-preview
#
# LLM_SCENARIO_DESCRIBE_PDF_PROVIDER=gemini
# LLM_SCENARIO_DESCRIBE_PDF_MODEL=gemini-3-flash-preview
#
# LLM_SCENARIO_TRANSCRIBE_AUDIO_PROVIDER=gemini
# LLM_SCENARIO_TRANSCRIBE_AUDIO_MODEL=gemini-3-flash-preview
#
# LLM_SCENARIO_GENERATE_GROUP_MEMORY_SUMMARY_MODEL=gpt-5.4
#
# LLM_SCENARIO_GENERATE_USER_MEMORY_PROFILE_MODEL=gpt-5.4

# ── Agent（可选；不填则继承默认 provider + 默认 model）────────────────────────
# LLM_AGENT_BASE_URL=http://127.0.0.1:8317/v1
# LLM_AGENT_API_KEY=sk-local
# LLM_AGENT_MODEL=gpt-5.1

# ── Tavily 网络搜索（可选）────────────────────────────────────────────────────
# TAVILY_API_KEY=tvly-xxxxx

# ── 日志文件（可选）───────────────────────────────────────────────────────────
# LOG_FILE_ENABLED=true
# LOG_FILE_PATH=/absolute/path/to/app.log

# ── 定时任务 ───────────────────────────────────────────────────────────────────
MEMORY_JOB_INTERVAL_HOURS=4
MEMORY_JOB_SKIP_THRESHOLD=20
JOB_INTER_DELAY_MS=200
