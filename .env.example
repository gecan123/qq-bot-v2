# ── 数据库 ────────────────────────────────────────────────────────────────────
# PostgreSQL 连接字符串
DATABASE_URL=postgresql://qq_user:qq_password@192.168.1.42:5432/qq_bot_v2

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis 连接字符串，用于消息队列
REDIS_URL=redis://127.0.0.1:6379

# ── NapCat（QQ 协议端）────────────────────────────────────────────────────────
# NapCat WebSocket 地址
NAPCAT_WS_URL=ws://localhost:3001
# NapCat 鉴权 Token，需与 NapCat 配置一致
NAPCAT_ACCESS_TOKEN=your_token_here

# ── Bot 基础配置 ───────────────────────────────────────────────────────────────
# 要监听的 QQ 群号，逗号分隔
GROUP_IDS=955646333,672312932,253631878
# Bot 自身的 QQ 号，用于过滤自发消息
SELF_NUMBER=3999414673

# ── 运行环境 ───────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── 媒体描述（可选）───────────────────────────────────────────────────────────
# 回复时等待媒体描述生成的最近 N 条消息数量（默认 5）
REPLY_MEDIA_WAIT_N=5
# 等待媒体描述生成的最长超时（毫秒），超时后降级为 [图片] 占位符（默认 5000）
REPLY_MEDIA_TIMEOUT_MS=5000

# ── LLM Provider ──────────────────────────────────────────────────────────────
# 默认 provider："gemini" 或 "openai"
# LLM_PROVIDER=openai

# Gemini 默认模型（默认 gemini-2.5-flash）
# GEMINI_MODEL=gemini-2.5-flash

# OpenAI-compatible API 配置
# OPENAI_BASE_URL=http://127.0.0.1:8317/v1
# OPENAI_API_KEY=sk-local
# OPENAI_MODEL=gpt-5.1   # 所有 openai 场景的默认模型

# ── 按场景覆盖 provider / model（可选）──────────────────────────────────────
# 每个场景可单独指定 provider 和 model，不填则继承默认值
# LLM_DESCRIBE_IMAGE_PROVIDER=openai
# LLM_DESCRIBE_IMAGE_MODEL=gpt-5.1-codex-mini
#
# LLM_SUMMARIZE_TEXT_PROVIDER=openai
# LLM_SUMMARIZE_TEXT_MODEL=gpt-5.1
#
# LLM_GENERATE_TEXT_PROVIDER=openai
# LLM_GENERATE_TEXT_MODEL=gpt-5.2
#
# LLM_GENERATE_REPLY_PROVIDER=openai
# LLM_GENERATE_REPLY_MODEL=gpt-5.1
#
# LLM_TRANSCRIBE_AUDIO_PROVIDER=openai
# LLM_TRANSCRIBE_AUDIO_MODEL=gpt-5.1

# ── 定时任务 ───────────────────────────────────────────────────────────────────
# 记忆整理任务的执行间隔（小时）
MEMORY_JOB_INTERVAL_HOURS=4
# 新消息数低于此阈值时跳过本轮整理
MEMORY_JOB_SKIP_THRESHOLD=20
# 队列中相邻两个 job 之间的延迟（毫秒），避免短时间内频繁请求外部服务
JOB_INTER_DELAY_MS=200
