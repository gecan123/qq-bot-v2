{
  "name": "qq-bot-v2",
  "version": "1.0.0",
  "description": "QQ Bot V2 - 纯消息存储 MVP",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "admin:dev": "pnpm --filter admin-web dev",
    "admin:build": "pnpm --filter admin-web build",
    "admin:start": "pnpm --filter admin-web start",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "test": "tsx --test src/**/*.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.17.1",
  "dependencies": {
    "@google/genai": "^1.41.0",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@tavily/core": "^0.7.2",
    "dotenv": "^17.3.1",
    "google-auth-library": "^9.0.0",
    "node-napcat-ts": "^0.4.21",
    "openai": "^6.31.0",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/pg": "^8.16.0",
    "prisma": "^7.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
