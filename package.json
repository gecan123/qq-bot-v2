{
  "name": "qq-bot-v2",
  "version": "1.0.0",
  "description": "QQ Bot V2 - 纯消息存储 MVP",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:once": "tsx src/index.ts",
    "build": "rm -rf dist && tsc && mkdir -p dist/agent/tools/ai-tone && cp src/agent/tools/ai-tone/model.json dist/agent/tools/ai-tone/model.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json",
    "lint": "pnpm typecheck && pnpm repo-check",
    "repo-check": "tsx scripts/repo-check.ts",
    "agent:doctor": "tsx scripts/agent-doctor.ts",
    "agent:metrics": "tsx scripts/agent-metrics.ts",
    "agent:daily-metrics": "tsx scripts/agent-daily-metrics.ts",
    "agent:memory-check": "tsx scripts/agent-memory-check.ts",
    "agent:ledger-check": "tsx scripts/agent-ledger-check.ts",
    "agent:context": "tsx scripts/agent-context.ts",
    "agent:reset-memory": "tsx scripts/reset-agent-memory.ts",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:query": "tsx scripts/agent-db-query.ts",
    "test": "tsx --test --import ./scripts/test-env.mjs --import tsx 'src/**/*.test.ts'",
    "tick": "kill -USR1 $(cat .bot.pid)",
    "peek": "tsx scripts/peek.ts",
    "peekf": "tsx scripts/peek.ts -f -n 9999",
    "browser:controller": "tsx scripts/browser-controller.ts",
    "toollog": "tail -n 50 logs/tool-calls.ndjson",
    "toollogf": "tail -f logs/tool-calls.ndjson"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.17.1",
  "dependencies": {
    "@google/genai": "^1.41.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@tavily/core": "^0.7.2",
    "cheerio": "^1.2.0",
    "cloakbrowser": "^0.4.3",
    "croner": "^10.0.1",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^5.7.2",
    "google-auth-library": "^9.0.0",
    "jsonrepair": "^3.13.3",
    "mmdb-lib": "^3.0.2",
    "node-napcat-ts": "^0.4.21",
    "openai": "^6.31.0",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "playwright-core": "^1.60.0",
    "sharp": "^0.34.5",
    "yaml": "^2.8.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/pg": "^8.16.0",
    "playwright": "^1.60.0",
    "prisma": "^7.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
