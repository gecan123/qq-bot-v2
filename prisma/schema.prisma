generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// 群消息 + 私聊事实账本。NapCat 入站 → upsert。bot 永远只读不改写。
/// resolvedText 在媒体描述完成后回填一次（一次性冻结）。
///
/// sceneKind = 'qq_group':   groupId 必填, sceneExternalId = ''
/// sceneKind = 'qq_private': groupId = null, sceneExternalId = String(peerId)
/// 见 src/database/messages.ts 入库前 invariant assert。
model Message {
  id                  Int       @id @default(autoincrement())
  sceneKind           String    @default("qq_group") @map("scene_kind") @db.VarChar(32)
  sceneExternalId     String    @default("") @map("scene_external_id") @db.VarChar(191)
  groupId             BigInt?   @map("group_id")
  groupName           String?   @map("group_name") @db.VarChar(255)
  mediaReferenceIds   String[]  @default([]) @map("media_reference_ids")
  messageId           BigInt    @map("message_id")
  senderId            BigInt    @map("sender_id")
  senderNickname      String?   @map("sender_nickname") @db.VarChar(100)
  senderGroupNickname String?   @map("sender_group_nickname") @db.VarChar(100)
  content             Json      @map("content")
  rawContent          Json?     @map("raw_content")
  rawMessage          String?   @map("raw_message") @db.Text
  searchText          String    @default("") @map("search_text") @db.Text
  resolvedText        String?   @map("resolved_text") @db.Text
  sentAt              DateTime? @map("sent_at") @db.Timestamptz(3)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  @@unique([sceneKind, sceneExternalId, messageId])
  @@index([groupId, createdAt(sort: Desc)])
  @@index([sceneKind, sceneExternalId, createdAt(sort: Desc)])
  @@map("messages")
}

/// 媒体二进制 + 描述缓存。jobQueue 异步生成 description_raw。
model Media {
  mediaId        Int      @id @default(autoincrement()) @map("media_id")
  data           Bytes    @map("data")
  dataHash       String?  @map("data_hash") @db.VarChar(64)
  mediaType      String?  @map("media_type")
  contentType    String?  @map("content_type")
  fileName       String?  @map("file_name")
  fileSize       Int?     @map("file_size")
  descriptionRaw Json?    @map("description_raw")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@unique([dataHash])
  @@map("media")
}

/// 单上下文 bot 的 AgentContext 持久化。永远只有 id=1 这一行。
/// 持久形态 == 运行时形态: contextSnapshot 字段就是 LLM 调用时直接喂的历史。
/// 详见 src/agent/agent-context.ts 和 AGENTS.md / CLAUDE.md「永续上下文契约」。
model BotAgentSnapshot {
  id              Int      @id @default(1)
  schemaVersion   Int      @default(1) @map("schema_version")
  contextSnapshot Json     @map("context_snapshot")
  lastWakeAt      DateTime? @map("last_wake_at") @db.Timestamptz(3)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("bot_agent_snapshot")
}

/// Luna 的长期记忆笔记本。bot 通过 remember / recall 工具自主读写,
/// 不自动注入 prefix (红线 1/4 不变)。content 是 Luna 自己写的笔记内容。
/// targetId 统一用 String 存 QQ号 / 群号: LLM 通过 z.union([str, num]) → String 传入,
/// 避免 BigInt JSON 序列化摩擦。
model MemoryEntry {
  id               Int      @id @default(autoincrement())
  targetKind       String   @map("target_kind") @db.VarChar(16)
  targetId         String   @map("target_id") @db.VarChar(64)
  content          String   @db.Text
  sourceMessageIds Json?    @map("source_message_ids")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([targetKind, targetId, createdAt(sort: Desc)])
  @@map("memory_entries")
}

/// Luna 的表情包收藏池。collect_sticker 工具写入, compaction 后注入摘要进 context。
/// mediaId 唯一 (一张图在池子里只有一个条目), 逻辑引用 Media 表的 mediaId。
model StickerPool {
  id          Int       @id @default(autoincrement())
  mediaId     Int       @unique @map("media_id")
  name        String    @db.VarChar(50)
  tags        String[]  @default([])
  description String    @db.Text
  useCount    Int       @default(0) @map("use_count")
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz(3)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([useCount(sort: Desc), createdAt(sort: Desc)])
  @@map("sticker_pool")
}

/// Agent 工具调用观测事件。运行时写入失败不能影响 bot 行为; 查询侧按需聚合。
model AgentToolCall {
  id          BigInt   @id @default(autoincrement())
  ts          DateTime @db.Timestamptz(3)
  toolCallId  String   @map("tool_call_id") @db.VarChar(191)
  toolName    String   @map("tool_name") @db.VarChar(191)
  roundIndex  Int      @map("round_index")
  argsSummary Json     @map("args_summary")
  durationMs  Int      @map("duration_ms")
  ok          Boolean
  sideEffect  Boolean  @map("side_effect")
  error       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([ts(sort: Desc)])
  @@index([toolName, ts(sort: Desc)])
  @@index([ok, ts(sort: Desc)])
  @@index([sideEffect, ts(sort: Desc)])
  @@map("agent_tool_calls")
}

/// Agent token/cache 使用观测事件。覆盖主聊天和 compaction 等 LLM operation。
model AgentTokenUsage {
  id           BigInt   @id @default(autoincrement())
  ts           DateTime @db.Timestamptz(3)
  operation    String   @db.VarChar(64)
  roundIndex   Int?     @map("round_index")
  model        String   @db.VarChar(191)
  inputTokens  Int?     @map("input_tokens")
  cachedTokens Int?     @map("cached_tokens")
  outputTokens Int?     @map("output_tokens")
  cacheHitRate Float?   @map("cache_hit_rate")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([ts(sort: Desc)])
  @@index([operation, ts(sort: Desc)])
  @@index([model, ts(sort: Desc)])
  @@map("agent_token_usage")
}
