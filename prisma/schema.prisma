generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Message {
  id                  Int       @id @default(autoincrement())
  sceneKind           String    @default("qq_group") @map("scene_kind") @db.VarChar(32)
  sceneExternalId     String    @default("") @map("scene_external_id") @db.VarChar(191)
  groupId             BigInt    @map("group_id")
  groupName           String?   @map("group_name") @db.VarChar(255)
  mediaReferenceIds   String[]  @default([]) @map("media_reference_ids")
  messageId           BigInt    @map("message_id")
  senderId            BigInt    @map("sender_id")
  senderNickname      String?   @map("sender_nickname") @db.VarChar(100)
  senderGroupNickname String?   @map("sender_group_nickname") @db.VarChar(100)
  content             Json      @map("content")
  rawContent          Json?     @map("raw_content")
  rawMessage          String?   @map("raw_message") @db.Text
  searchText          String    @default("") @map("search_text") @db.Text
  resolvedText        String?   @map("resolved_text") @db.Text
  sentAt              DateTime? @map("sent_at") @db.Timestamptz(3)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  @@unique([sceneKind, sceneExternalId, messageId])
  @@index([groupId, createdAt(sort: Desc)])
  @@index([sceneKind, sceneExternalId, createdAt(sort: Desc)])
  @@map("messages")
}

model Media {
  mediaId        Int      @id @default(autoincrement()) @map("media_id")
  data           Bytes    @map("data")
  dataHash       String?  @map("data_hash") @db.VarChar(64)
  mediaType      String?  @map("media_type")
  contentType    String?  @map("content_type")
  fileName       String?  @map("file_name")
  fileSize       Int?     @map("file_size")
  descriptionRaw Json?    @map("description_raw")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@unique([dataHash])
  @@map("media")
}

model LlmTrace {
  id         Int      @id @default(autoincrement())
  groupId    BigInt   @map("group_id")
  model      String?  @db.VarChar(128)
  input      Json     @map("input")
  output     Json?    @map("output")
  durationMs Int      @map("duration_ms")
  error      String?  @map("error") @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([groupId, createdAt(sort: Desc)])
  @@map("llm_traces")
}

model ConversationState {
  id                        Int      @id @default(autoincrement())
  groupId                   BigInt   @map("group_id")
  senderThreadKey           String   @map("sender_thread_key") @db.VarChar(128)
  compactedBase             String   @default("") @map("compacted_base") @db.Text
  compactedVersion          Int      @default(1) @map("compacted_version")
  lastCompactedMessageRowId Int?     @map("last_compacted_message_row_id")
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                 DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([groupId, senderThreadKey])
  @@index([groupId, updatedAt(sort: Desc)])
  @@map("conversation_states")
}

model AssistantTurn {
  id                       Int      @id @default(autoincrement())
  groupId                  BigInt   @map("group_id")
  senderThreadKey          String   @map("sender_thread_key") @db.VarChar(128)
  replyIntentId            String   @map("reply_intent_id") @db.VarChar(191)
  triggerMessageRowId      Int      @map("trigger_message_row_id")
  incorporatedMessageRowId Int      @map("incorporated_message_row_id")
  sequence                 Int      @map("sequence")
  replyToMessageId         BigInt   @map("reply_to_message_id")
  mentionUserId            BigInt?  @map("mention_user_id")
  providerMessageId        BigInt?  @map("provider_message_id")
  text                     String   @map("text") @db.Text
  status                   String   @map("status") @db.VarChar(32)
  attemptCount             Int      @default(0) @map("attempt_count")
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([groupId, senderThreadKey, replyIntentId])
  @@unique([groupId, senderThreadKey, sequence])
  @@index([groupId, senderThreadKey, triggerMessageRowId])
  @@index([groupId, senderThreadKey, updatedAt(sort: Desc)])
  @@map("assistant_turns")
}

model ReplyAudit {
  id            Int      @id @default(autoincrement())
  runtimeKey    String   @map("runtime_key") @db.VarChar(191)
  groupId       BigInt   @map("group_id")
  scopeKey      String   @map("scope_key") @db.VarChar(191)
  replyIntentId String   @map("reply_intent_id") @db.VarChar(191)
  opportunityId String   @default("") @map("opportunity_id") @db.VarChar(191)
  auditKind     String   @map("audit_kind") @db.VarChar(32)
  payload       Json     @map("payload")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@unique([runtimeKey, opportunityId, auditKind])
  @@index([groupId, scopeKey, createdAt(sort: Desc)])
  @@map("reply_audits")
}

model AgentRuntimeSnapshot {
  id              Int      @id @default(autoincrement())
  agentId         String   @map("agent_id") @db.VarChar(191)
  schemaVersion   Int      @map("schema_version")
  contextSnapshot Json     @map("context_snapshot")
  sessionSnapshot Json     @map("session_snapshot")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([agentId])
  @@map("agent_runtime_snapshots")
}

model Scene {
  id          String   @id @db.VarChar(191)
  agentId     String   @map("agent_id") @db.VarChar(191)
  kind        String   @db.VarChar(32)
  externalId  String   @map("external_id") @db.VarChar(191)
  displayName String?  @map("display_name") @db.VarChar(255)
  policy      Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([agentId, kind, externalId])
  @@index([agentId, updatedAt(sort: Desc)])
  @@map("scenes")
}

model RuntimeEvent {
  id             String    @id @db.VarChar(191)
  sceneId        String    @map("scene_id") @db.VarChar(191)
  eventType      String    @map("event_type") @db.VarChar(64)
  payload        Json
  occurredAt     DateTime  @map("occurred_at") @db.Timestamptz(3)
  idempotencyKey String    @map("idempotency_key") @db.VarChar(191)
  consumedAt     DateTime? @map("consumed_at") @db.Timestamptz(3)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  @@unique([sceneId, idempotencyKey])
  @@index([sceneId, occurredAt(sort: Desc)])
  @@map("runtime_events")
}

model Opportunity {
  id              String    @id @db.VarChar(191)
  sceneId         String    @map("scene_id") @db.VarChar(191)
  runtimeEventId  String?   @map("runtime_event_id") @db.VarChar(191)
  queueKind       String    @map("queue_kind") @db.VarChar(32)
  opportunityType String    @map("opportunity_type") @db.VarChar(64)
  priority        Int       @default(0)
  deadlineAt      DateTime? @map("deadline_at") @db.Timestamptz(3)
  payload         Json
  status          String    @default("pending") @db.VarChar(32)
  idempotencyKey  String    @map("idempotency_key") @db.VarChar(191)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([sceneId, idempotencyKey])
  @@index([sceneId, status, priority(sort: Desc), createdAt])
  @@map("opportunities")
}

model ActionIntent {
  id             String   @id @db.VarChar(191)
  opportunityId  String   @map("opportunity_id") @db.VarChar(191)
  decisionId     String?  @map("decision_id") @db.VarChar(191)
  actionType     String   @map("action_type") @db.VarChar(64)
  targetSceneId  String   @map("target_scene_id") @db.VarChar(191)
  payload        Json
  dryRun         Boolean  @default(false) @map("dry_run")
  riskLevel      String   @default("L1") @map("risk_level") @db.VarChar(32)
  status         String   @default("proposed") @db.VarChar(32)
  idempotencyKey String   @map("idempotency_key") @db.VarChar(191)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([opportunityId, idempotencyKey])
  @@index([decisionId])
  @@index([targetSceneId, status, createdAt])
  @@map("action_intents")
}

model Decision {
  id             String   @id @db.VarChar(191)
  opportunityId  String   @map("opportunity_id") @db.VarChar(191)
  idempotencyKey String   @map("idempotency_key") @db.VarChar(191)
  policyVersion  String   @map("policy_version") @db.VarChar(64)
  verdict        String   @db.VarChar(32)
  riskLevel      String   @map("risk_level") @db.VarChar(32)
  reason         String   @db.Text
  barrierInput   Json     @map("barrier_input")
  barrierOutput  Json     @map("barrier_output")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@unique([opportunityId, idempotencyKey])
  @@index([opportunityId, createdAt])
  @@map("decisions")
}

model ActionRecord {
  id             String   @id @db.VarChar(191)
  actionIntentId String   @map("action_intent_id") @db.VarChar(191)
  actionType     String   @map("action_type") @db.VarChar(64)
  targetSceneId  String   @map("target_scene_id") @db.VarChar(191)
  deliveryState  String   @map("delivery_state") @db.VarChar(32)
  idempotencyKey String   @map("idempotency_key") @db.VarChar(191)
  resultPayload  Json?    @map("result_payload")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([idempotencyKey])
  @@index([targetSceneId, deliveryState, createdAt])
  @@map("action_records")
}

model MemoryItem {
  id               String    @id @db.VarChar(191)
  agentId          String    @map("agent_id") @db.VarChar(191)
  scope            String    @db.VarChar(64)
  memoryType       String    @map("memory_type") @db.VarChar(64)
  sourceRef        Json      @map("source_ref")
  sourceProposalId String?   @unique @map("source_proposal_id") @db.VarChar(191)
  payload          Json
  confidence       Float?
  salience         Float?
  status           String    @default("active") @db.VarChar(32)
  decayPolicy      Json?     @map("decay_policy")
  expiresAt        DateTime? @map("expires_at") @db.Timestamptz(3)
  acceptedAt       DateTime? @map("accepted_at") @db.Timestamptz(3)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([agentId, scope, updatedAt(sort: Desc)])
  @@index([agentId, memoryType, status, updatedAt(sort: Desc)])
  @@map("memory_items")
}

model MemoryProposal {
  id             String    @id @db.VarChar(191)
  agentId        String    @map("agent_id") @db.VarChar(191)
  sourceRef      Json      @map("source_ref")
  proposalType   String    @map("proposal_type") @db.VarChar(64)
  payload        Json
  confidence     Float?
  salience       Float?
  status         String    @default("proposed") @db.VarChar(32)
  decayPolicy    Json?     @map("decay_policy")
  expiresAt      DateTime? @map("expires_at") @db.Timestamptz(3)
  idempotencyKey String    @map("idempotency_key") @db.VarChar(191)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([agentId, idempotencyKey])
  @@index([agentId, status, createdAt])
  @@map("memory_proposals")
}

model SelfSpineUpdateProposal {
  id             String    @id @db.VarChar(191)
  agentId        String    @map("agent_id") @db.VarChar(191)
  sourceRef      Json      @map("source_ref")
  patch          Json
  rationale      String    @db.Text
  status         String    @default("proposed") @db.VarChar(32)
  idempotencyKey String    @map("idempotency_key") @db.VarChar(191)
  reviewedBy     String?   @map("reviewed_by") @db.VarChar(191)
  reviewedAt     DateTime? @map("reviewed_at") @db.Timestamptz(3)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([agentId, idempotencyKey])
  @@index([agentId, status, createdAt])
  @@map("self_spine_update_proposals")
}

model SelfSpineVersion {
  id                String   @id @db.VarChar(191)
  agentId           String   @map("agent_id") @db.VarChar(191)
  version           Int
  snapshot          Json
  diff              Json
  sourceProposalId  String?  @unique @map("source_proposal_id") @db.VarChar(191)
  rollbackOfVersion Int?     @map("rollback_of_version")
  status            String   @default("active") @db.VarChar(32)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@unique([agentId, version])
  @@index([agentId, status, version])
  @@map("self_spine_versions")
}

model FeedSource {
  id          String   @id @db.VarChar(191)
  sceneId     String   @map("scene_id") @db.VarChar(191)
  kind        String   @db.VarChar(32)
  externalId  String   @map("external_id") @db.VarChar(191)
  displayName String?  @map("display_name") @db.VarChar(255)
  config      Json?
  status      String   @default("active") @db.VarChar(32)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([kind, externalId])
  @@index([sceneId, status])
  @@map("feed_sources")
}

model FeedItem {
  id           String    @id @db.VarChar(191)
  feedSourceId String    @map("feed_source_id") @db.VarChar(191)
  externalId   String    @map("external_id") @db.VarChar(191)
  url          String?   @db.Text
  title        String    @db.Text
  author       String?   @db.VarChar(255)
  rawContent   String?   @map("raw_content") @db.Text
  contentHash  String?   @map("content_hash") @db.VarChar(64)
  publishedAt  DateTime? @map("published_at") @db.Timestamptz(3)
  seenAt       DateTime  @default(now()) @map("seen_at") @db.Timestamptz(3)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([feedSourceId, externalId])
  @@index([feedSourceId, seenAt(sort: Desc)])
  @@map("feed_items")
}

model ReadSession {
  id              String    @id @db.VarChar(191)
  feedItemId      String    @map("feed_item_id") @db.VarChar(191)
  contentHash     String?   @map("content_hash") @db.VarChar(64)
  opportunityId   String    @map("opportunity_id") @db.VarChar(191)
  actionRecordId  String?   @map("action_record_id") @db.VarChar(191)
  selectionReason String    @map("selection_reason") @db.Text
  status          String    @default("completed") @db.VarChar(32)
  startedAt       DateTime  @default(now()) @map("started_at") @db.Timestamptz(3)
  completedAt     DateTime? @map("completed_at") @db.Timestamptz(3)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([feedItemId, createdAt])
  @@index([feedItemId, contentHash, createdAt])
  @@index([opportunityId])
  @@map("read_sessions")
}

model SourceSummary {
  id            String   @id @db.VarChar(191)
  readSessionId String   @map("read_session_id") @db.VarChar(191)
  summary       String   @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([readSessionId])
  @@map("source_summaries")
}

model ThoughtArtifact {
  id            String   @id @db.VarChar(191)
  readSessionId String   @map("read_session_id") @db.VarChar(191)
  thought       String   @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([readSessionId])
  @@map("thought_artifacts")
}

model RationaleArtifact {
  id            String   @id @db.VarChar(191)
  readSessionId String   @map("read_session_id") @db.VarChar(191)
  rationale     String   @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([readSessionId])
  @@map("rationale_artifacts")
}
