# Per-group prompt customization (模板).
#
# 真实使用: copy 一份到 ./prompts/groups.yaml 并填上自己的群号 / 描述.
# `prompts/groups.yaml` 被 .gitignore (含真实群号 + body 不入 git);
# 这份 example 是 schema 文档 + 占位示例, 进 git.
#
# loader 行为:
# - `./prompts/groups.yaml` 存在 → 启动期一次 load, 通过 source_profile 工具按需返回
# - 不存在 → 返空数组 (= 所有群走默认人设, 不阻断启动)
# - 改这个文件需要重启 bot (工具侧数据启动期冻结; system prompt 字节不变)
# - 集中改, 不要小步频改
#
# fallback 语义:
# - BOT_TARGET_GROUP_IDS 里但 yaml 里没条目的群 → source_profile 返回 normal + 空 body,
#   走基础人设 (= 等价于 frequency_hint=normal + 空 body)
# - yaml 里写一个不在白名单里的 id → 不报错, 但 source_profile 不会为它提供可用结果
#
# ─── schema ─────────────────────────────────────────────────────────────────
# groups: 数组, 每项三字段 (全 required):
#   id              integer  群号 (必须在 BOT_TARGET_GROUP_IDS 里才可通过 source_profile 使用)
#   frequency_hint  enum     发言节奏倾向, 4 档:
#                              lurker - 几乎只在被 @ 时回; 主动开话题 + 空闲 fetch 都很谨慎
#                              quiet  - 偏被动; 真有内容才发, 主动话题少
#                              normal - 默认行为 (跟人设基座一致)
#                              chatty - 主动接话题; 空闲时更愿意 fetch + 发
#   body            string   自由文本, 这个群的话题取向 / 上下文 / 注意事项.
#                            允许空串 "" (= 只用 frequency_hint, 不加额外说明).
# ───────────────────────────────────────────────────────────────────────────

groups:
  - id: 111111111
    frequency_hint: chatty
    body: |
      <群名> — 主要聊 <topic>。<其它注意事项>。

  - id: 222222222
    frequency_hint: quiet
    body: |
      <群名> — 工作群。被 @ 才回, 主动开新话题谨慎。
